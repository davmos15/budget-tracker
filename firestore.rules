rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User document rules
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Owner has full write access
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        // Allow other authenticated users to only modify sharedBudgets (for invite-by-email)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedBudgets'])
      );

      // User's budgets subcollection
      match /budgets/{budgetId} {
        // Users can read budgets they own or are members of
        allow read: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.uid in resource.data.info.members
        );

        // Only the budget owner can create budgets in their collection
        allow create: if request.auth != null &&
          request.auth.uid == userId &&
          request.auth.uid == request.resource.data.info.createdBy &&
          request.auth.uid in request.resource.data.info.members &&
          request.auth.uid in request.resource.data.info.admins;

        // Members can update, but only admins can modify members/admins lists
        // Non-members can join (add themselves to members) if they only modify the members field
        allow update: if request.auth != null && (
          (
            // Existing members can update
            request.auth.uid in resource.data.info.members &&
            (
              !request.resource.data.info.diff(resource.data.info).affectedKeys().hasAny(['members', 'admins']) ||
              (request.auth.uid in resource.data.info.admins || request.auth.uid == resource.data.info.createdBy)
            )
          ) ||
          (
            // Non-members can join: only adding themselves to the members array, no other changes
            !(request.auth.uid in resource.data.info.members) &&
            request.resource.data.info.members.hasAll(resource.data.info.members) &&
            request.resource.data.info.members.hasAny([request.auth.uid]) &&
            request.resource.data.info.members.size() == resource.data.info.members.size() + 1 &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['info']) &&
            request.resource.data.info.diff(resource.data.info).affectedKeys().hasOnly(['members'])
          )
        );

        // Only the creator can delete
        allow delete: if request.auth != null &&
          request.auth.uid == resource.data.info.createdBy;
      }
    }

    // Email lookup collection for invite-by-email
    // Any authenticated user can read (to look up by email)
    // Users can only write their own email entry
    match /userEmails/{email} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
    }

    // Budget code lookup collection - any authenticated user can read to join
    // Only the budget owner can create/update their code entry
    match /budgetCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }
  }
}
